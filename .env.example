# ── Virasat environment variables ──────────────────────────────────────────
# Copy this file to .env and fill in real values. NEVER commit .env.

# Google Gemini API key (required for all AI features).
# Get a free key at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Optional: override the Gemini model (defaults to gemini-2.5-flash)
GEMINI_MODEL=gemini-2.5-flash

# Postgres connection string (required). Neon (https://neon.tech) free tier
# works locally and on Vercel — use the pooled connection string.
DATABASE_URL=

# Secret for signing session JWTs (required, minimum 32 characters).
# Generate one with:  node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
AUTH_SECRET=
